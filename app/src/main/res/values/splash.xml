<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Nur Hintergrund, damit der Übergang zum Compose-Overlay unsichtbar ist -->
        <item name="windowSplashScreenBackground">#0B1221</item>

        <!-- Wir lassen das Icon leer oder nutzen ein transparentes Pixel, um Doppelung zu vermeiden -->
        <item name="windowSplashScreenAnimatedIcon">@android:color/transparent</item>

        <item name="postSplashScreenTheme">@style/Theme.FahrstuhlKartenspiel</item>
    </style>
</resources>
